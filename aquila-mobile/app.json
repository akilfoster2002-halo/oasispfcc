{
  "expo": {
    "name": "Aquila",
    "slug": "aquila-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#111318",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oasispfcc.aquila",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.oasispfcc.aquila",
      "adaptiveIcon": {
        "backgroundColor": "#111318",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "scheme": "aquila",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1040b47b-0503-424d-b2ff-644fe81b52f7"
      }
    }
  }
}
